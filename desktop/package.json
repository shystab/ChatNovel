{
  "name": "novel-ide-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for Novel IDE",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "prepare:resources": "node scripts/prepare-resources.js",
    "pack": "npm run prepare:resources && electron-builder --dir",
    "dist": "npm run prepare:resources && electron-builder",
    "pack:shell": "electron-builder --dir",
    "dist:shell": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.shysta.novelide",
    "productName": "Novel IDE",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-resources/backend",
        "to": "backend"
      },
      {
        "from": "build-resources/frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
