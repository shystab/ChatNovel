# Server frontend example
# Copy this to frontend/.env.local before building the frontend on the server.

NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://your-domain.com/api/v1/ai/ws

# Must match backend APP_ACCESS_TOKEN if enabled.
NEXT_PUBLIC_APP_ACCESS_TOKEN=change-this-long-random-token
